{
  "name": "ayati-git-context",
  "version": "0.1.0",
  "description": "Independent Git and SQLite context service for Ayati",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "ayati-git-context": "dist/server-main.js"
  },
  "scripts": {
    "build": "node ../scripts/clean-dist.mjs . && tsc",
    "start": "node dist/server-main.js",
    "dev": "pnpm build && pnpm start",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "git",
    "context",
    "agent"
  ],
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
