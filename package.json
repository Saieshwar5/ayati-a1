{
  "name": "ayati",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "dev:main": "pnpm --filter ayati-git-context build && pnpm --filter ayati-main dev",
    "dev:git-context": "pnpm --filter ayati-git-context dev",
    "dev:main:feedback": "pnpm --filter ayati-git-context build && AYATI_TEST_AGENT=1 AYATI_FEEDBACK_TRACE=1 pnpm --filter ayati-main dev",
    "dev:cli": "pnpm --filter ayati-cli dev",
    "start:main": "pnpm --filter ayati-main start",
    "start:git-context": "pnpm --filter ayati-git-context start",
    "context:archive-reset": "node --env-file-if-exists=.env scripts/context-archive-reset.mjs",
    "start:main:feedback": "AYATI_TEST_AGENT=1 AYATI_FEEDBACK_TRACE=1 pnpm --filter ayati-main start",
    "feedback:git-context": "node scripts/git-context-feedback-report.mjs",
    "start:cli": "pnpm --filter ayati-cli start",
    "doctor:main": "pnpm --filter ayati-main run doctor"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
