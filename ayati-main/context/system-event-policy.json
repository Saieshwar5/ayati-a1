{
  "schemaVersion": 2,
  "defaults": {
    "mode": "analyze_notify"
  },
  "rules": [
    {
      "source": "pulse",
      "eventClass": "trigger_fired",
      "createdBy": "user",
      "mode": "auto_execute_notify"
    },
    {
      "source": "agentmail",
      "eventClass": "message_received",
      "mode": "analyze_ask"
    },
    {
      "source": "nylas-mail",
      "eventClass": "message_received",
      "mode": "analyze_ask"
    },
    {
      "source": "gmail-cli",
      "eventName": "new_messages",
      "mode": "analyze_ask"
    },
    {
      "source": "calendar-sync",
      "eventClass": "state_changed",
      "mode": "log_only"
    }
  ]
}
