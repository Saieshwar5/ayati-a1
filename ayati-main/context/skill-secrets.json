{
  "google.workspace.oauth": {
    "source": "env",
    "env": "GOOGLE_WORKSPACE_OAUTH_JSON"
  },
  "github.token": {
    "source": "env",
    "env": "GITHUB_TOKEN"
  },
  "serpapi.api_key": {
    "source": "env",
    "env": "SERPAPI_API_KEY"
  },
  "agentmail.api_key": {
    "source": "env",
    "env": "AGENTMAIL_API_KEY"
  },
  "agentmail.inbox_id": {
    "source": "env",
    "env": "AGENTMAIL_INBOX_ID"
  },
  "nylas.api_key": {
    "source": "env",
    "env": "NYLAS_API_KEY"
  },
  "nylas.grant_id": {
    "source": "env",
    "env": "NYLAS_GRANT_ID"
  }
}
