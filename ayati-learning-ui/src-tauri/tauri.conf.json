{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ayati Learning Workspace",
  "version": "0.1.0",
  "identifier": "dev.ayati.learning",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:5174",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ayati Learning Workspace",
        "width": 1240,
        "height": 820,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
